# Copy this file to .env and fill in your real values.
# Never commit the real .env file — it's already in .gitignore.

# Get this from https://resend.com after signing up (free tier available)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form messages get sent
CONTACT_TO_EMAIL=jansidoshi4@gmail.com

# Resend's shared sandbox sender — works immediately, no domain setup needed.
# Once you verify your own domain on Resend, you can switch this to something
# like "contact@yourdomain.com" for a more polished "from" address.
CONTACT_FROM_EMAIL=onboarding@resend.dev
